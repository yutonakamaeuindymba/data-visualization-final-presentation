      <aliases enabled='yes' />
      <column caption='Month' datatype='datetime' name='[Calculation_1301605931393024]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;,[Transaction Date])' />
      </column>
      <column caption='Day of Week' datatype='string' name='[Calculation_1301605931425793]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;weekday&apos;,[Transaction Date])' />
      </column>
      <column caption='Month Label' datatype='string' name='[Calculation_1301605931495426]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;month&apos;,[Transaction Date]) + &quot; &quot; + STR(YEAR([Transaction Date]))' />
      </column>
      <column caption='ATV' datatype='real' name='[Calculation_1301605931552771]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Total Spent]) / COUNTD([Transaction ID])' />
      </column>
      <column caption='Item Revenue' datatype='real' name='[Calculation_1301605931622404]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Total Spent])' />
      </column>
      <column caption='MoM % Change' datatype='real' name='[Calculation_1301605931671557]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Total Spent]) - LOOKUP(SUM([Total Spent]), -1))&#10;/ LOOKUP(SUM([Total Spent]), -1)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Top 1 Revenue' datatype='real' name='[Calculation_1301605933465609]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Item Set] THEN [Total Spent] END' />
      </column>
      <column caption='Top 1 Item %' datatype='real' name='[Calculation_1301605934129162]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_1301605933465609]) / SUM([Total Spent])' />
      </column>
      <column caption='Top 1 Item Name' datatype='string' name='[Calculation_1301605934776331]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Item Set] THEN [Item] END' />
      </column>
      <column caption='Revenue per Day' datatype='real' name='[Calculation_1301605943103502]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Total Spent]) / COUNTD([Transaction Date])' />
      </column>
      <column datatype='string' name='[Item]' role='dimension' type='nominal' />
      <column datatype='real' name='[Total Spent]' role='measure' type='quantitative' />
      <column caption='Coffee Shop Dataset.csv' datatype='table' name='[__tableau_internal_object_id__].[Coffee Shop Dataset.csv_872EC25BF68B458783D660F6671153D1]' role='measure' type='quantitative' />
      <column-instance column='[Item]' derivation='None' name='[none:Item:nk]' pivot='key' type='nominal' />
      <group caption='Action (Item)' hidden='true' name='[Action (Item)]' name-style='unqualified' user:auto-column='sheet_link'>
