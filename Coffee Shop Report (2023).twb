    <worksheet name='Revenue Trend'>
      <table>
        <view>
          <datasources>
            <datasource caption='Coffee Shop Dataset' name='federated.0yt02sz0llq4ig150mzbw05cfnfr' />
          </datasources>
          <datasource-dependencies datasource='federated.0yt02sz0llq4ig150mzbw05cfnfr'>
            <column caption='MoM % Change' datatype='real' name='[Calculation_1301605931671557]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([Total Spent]) - LOOKUP(SUM([Total Spent]), -1))&#10;/ LOOKUP(SUM([Total Spent]), -1)'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column datatype='string' name='[Item]' role='dimension' type='nominal' />
